<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clash Navigator"
        Height="760" Width="1120"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip"
        Background="#221A30">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg"        Color="#221A30"/>
        <SolidColorBrush x:Key="Surface"   Color="#2C2240"/>
        <SolidColorBrush x:Key="Input"     Color="#352A4D"/>
        <SolidColorBrush x:Key="Brd"       Color="#4A3D6B"/>
        <SolidColorBrush x:Key="Accent"    Color="#7F77DD"/>
        <SolidColorBrush x:Key="AccentDk"  Color="#534AB7"/>
        <SolidColorBrush x:Key="HeaderBg"  Color="#3C3489"/>
        <SolidColorBrush x:Key="Txt"       Color="#ECE8F7"/>
        <SolidColorBrush x:Key="TxtMuted"  Color="#B8AFD6"/>
        <SolidColorBrush x:Key="Row"       Color="#2A2040"/>
        <SolidColorBrush x:Key="RowAlt"    Color="#31264A"/>
        <SolidColorBrush x:Key="DropBg"    Color="#F4F2FB"/>
        <SolidColorBrush x:Key="DropTxt"   Color="#161019"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="Background" Value="{StaticResource AccentDk}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{StaticResource Input}"/>
                                <Setter Property="Foreground" Value="{StaticResource TxtMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="Background" Value="{StaticResource Input}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brd}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentDk}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentDk}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="Background" Value="{StaticResource Input}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brd}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="CaretBrush" Value="{StaticResource Txt}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="Background" Value="{StaticResource Input}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brd}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Focusable="false" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{StaticResource Input}"
                                                BorderBrush="{StaticResource Brd}" BorderThickness="1" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z" Fill="{StaticResource Txt}"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,23,0" VerticalAlignment="Center" HorizontalAlignment="Left"
                                              TextElement.Foreground="{StaticResource Txt}"/>
                            <Popup Name="Popup" Placement="Bottom" Focusable="False" AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="{StaticResource DropBg}" BorderBrush="{StaticResource Accent}"
                                        BorderThickness="1" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="250"
                                        TextElement.Foreground="{StaticResource DropTxt}">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource DropTxt}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentDk}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brd}"/>
            <Setter Property="RowBackground" Value="{StaticResource Row}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource RowAlt}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Brd}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource Brd}"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brd}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource Row}"/>
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Accent}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= Header / branding banner ================= -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CA TOOLS logo badge -->
            <Border Grid.Column="0" Background="#0A0710" Width="124" Height="72"
                    HorizontalAlignment="Left" VerticalAlignment="Top">
                <Image x:Name="logo_img" Stretch="Uniform" Margin="12,9,12,9"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True"/>
            </Border>

            <!-- App title / brand strip -->
            <Border Grid.Column="1" Background="{StaticResource HeaderBg}" Height="72"
                    Margin="0,0,0,0" VerticalAlignment="Top">
                <StackPanel VerticalAlignment="Center" Margin="18,0,18,0">
                    <TextBlock Text="CLASH NAVIGATOR" FontSize="19" FontWeight="Bold"
                               Foreground="{StaticResource Txt}"/>
                    <TextBlock Text="Navisworks clash coordination for Revit" FontSize="11"
                               Foreground="{StaticResource TxtMuted}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="10,0,10,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                <Button x:Name="load_btn" Content="Load Report (XML / HTML)..."
                        Padding="12,6" Margin="0,0,6,0" FontWeight="Bold"
                        ToolTip="Load a single Navisworks clash report — XML or HTML (tabular). HTML reports also load the clash viewpoint images."/>
                <Button x:Name="load_many_btn" Content="Load Multiple..."
                        Padding="12,6" Margin="0,0,6,0" FontWeight="Bold"
                        ToolTip="Load several clash reports at once, then switch between them with the Report dropdown."/>
                <Button x:Name="last_btn" Content="Last Report" Padding="12,6" Margin="0,0,6,0"
                        ToolTip="Reload the most recently used clash report"/>
                <Button x:Name="reset_last_btn" Content="Reset Last Report" Padding="12,6"
                        ToolTip="Forget the remembered last report"/>
            </StackPanel>

            <TextBlock Grid.Column="1" Text="Level:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="level_cb" Grid.Column="2" Height="26" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Column="4" Text="Search:" VerticalAlignment="Center" Margin="16,0,6,0"/>
            <TextBox x:Name="search_tb" Grid.Column="5" Height="26" VerticalContentAlignment="Center"/>
        </Grid>

        <!-- Loaded reports selector -->
        <Grid x:Name="report_bar" Grid.Row="2" Margin="10,0,10,8" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Report:" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="report_cb" Grid.Column="1" Height="26"
                      VerticalContentAlignment="Center"
                      ToolTip="Switch between the clash reports you have loaded."/>
            <TextBlock x:Name="report_count_tb" Grid.Column="2" Text=""
                       VerticalAlignment="Center" Margin="10,0,10,0"
                       Foreground="#B8AFD6"/>
            <Button x:Name="close_report_btn" Grid.Column="3" Content="Remove This Report"
                    Padding="10,4"
                    ToolTip="Remove the selected report from the loaded list."/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="10,0,10,6">
            <CheckBox x:Name="autozoom_cb" Content="Auto zoom + select on row click"
                      IsChecked="True" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="10,0,10,8">
            <TextBlock Text="Filters:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>

            <Grid Margin="0,0,10,0">
                <ToggleButton x:Name="status_toggle" Content="Status: All"
                              Width="150" Height="26" HorizontalContentAlignment="Left" Padding="8,0"/>
                <Popup x:Name="status_popup" PlacementTarget="{Binding ElementName=status_toggle}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="#2C2240" BorderBrush="#7F77DD" BorderThickness="1" Padding="2">
                        <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="status_list" MinWidth="155" Margin="4"/>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>

            <Grid Margin="0,0,10,0">
                <ToggleButton x:Name="disc_toggle" Content="Discipline: All"
                              Width="165" Height="26" HorizontalContentAlignment="Left" Padding="8,0"/>
                <Popup x:Name="disc_popup" PlacementTarget="{Binding ElementName=disc_toggle}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="#2C2240" BorderBrush="#7F77DD" BorderThickness="1" Padding="2">
                        <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="disc_list" MinWidth="175" Margin="4"/>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>

            <Grid Margin="0,0,10,0">
                <ToggleButton x:Name="inmodel_toggle" Content="In Model: All"
                              Width="135" Height="26" HorizontalContentAlignment="Left" Padding="8,0"/>
                <Popup x:Name="inmodel_popup" PlacementTarget="{Binding ElementName=inmodel_toggle}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="#2C2240" BorderBrush="#7F77DD" BorderThickness="1" Padding="2">
                        <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="inmodel_list" MinWidth="145" Margin="4"/>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>

            <Button x:Name="reset_filters_btn" Content="Reset Filters" Padding="10,4"/>
        </StackPanel>

        <!-- ================= Grid + clash image preview ================= -->
        <Grid Grid.Row="5" Margin="10,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="grid" Grid.Column="0"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserResizeRows="False"
                      CanUserAddRows="False"
                      BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Clash" Binding="{Binding Clash}" Width="80" IsReadOnly="True"/>
                    <DataGridComboBoxColumn x:Name="status_col" Header="Status"
                                            SelectedItemBinding="{Binding Status, UpdateSourceTrigger=PropertyChanged}"
                                            Width="95"/>
                    <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="95" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Discipline" Binding="{Binding Discipline}" Width="140" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Host Model ID" Binding="{Binding Id1}" Width="105" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Found (Host)" Binding="{Binding In1}" Width="90" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Link Model ID" Binding="{Binding Id2}" Width="105" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Found (Link)" Binding="{Binding In2}" Width="90" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Item Names" Binding="{Binding Items}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Img" Binding="{Binding Img}" Width="42" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- clash viewpoint image preview (shown for HTML / XML reports with images) -->
            <Border x:Name="preview_panel" Grid.Column="1" Width="272" Margin="8,0,0,0"
                    Background="#2C2240" BorderBrush="#4A3D6B" BorderThickness="1"
                    Visibility="Collapsed">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="preview_title" Grid.Row="0" Text="Clash View"
                               FontWeight="Bold" Margin="0,0,0,6"/>
                    <Border Grid.Row="1" Background="#221A30" BorderBrush="#4A3D6B" BorderThickness="1">
                        <Image x:Name="preview_img" Stretch="Uniform" Margin="4"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <Button x:Name="open_img_btn" Grid.Row="2" Content="Open Full Size"
                            Padding="10,5" Margin="0,8,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="10,8,10,0">
            <Button x:Name="select_btn"    Content="Select + Copy Host ID"  Padding="12,6" Margin="0,0,8,0"
                    ToolTip="Select and zoom to the host-model element, and copy its Element ID to the clipboard."/>
            <Button x:Name="select2_btn"   Content="Select + Copy Link ID"  Padding="12,6" Margin="0,0,8,0"
                    ToolTip="Select and zoom to the linked-model element, and copy its Element ID to the clipboard."/>
            <Button x:Name="both_btn"      Content="Select Both + Zoom"     Padding="12,6" Margin="0,0,8,0"/>
            <Button x:Name="highlight_btn" Content="Highlight (orange)"     Padding="12,6" Margin="0,0,8,0"/>
            <Button x:Name="clear_btn"     Content="Clear Highlights"       Padding="12,6" Margin="0,0,8,0"/>
            <Button x:Name="export_btn"    Content="Export Status CSV"      Padding="12,6"
                    ToolTip="Save current clash statuses to a CSV file"/>
        </StackPanel>

        <Border Grid.Row="7" Background="#2C2240" Margin="10,8,10,0" Padding="8,5"
                BorderBrush="#4A3D6B" BorderThickness="0,1,0,0">
            <TextBlock x:Name="status_tb" Text="Load a Navisworks clash report (XML or HTML) to begin."
                       Foreground="#B8AFD6" TextTrimming="CharacterEllipsis"/>
        </Border>

        <Grid Grid.Row="8" Margin="12,6,12,10">
            <TextBlock x:Name="version_tb" Text="v2.0.0"
                       HorizontalAlignment="Left" VerticalAlignment="Center"
                       FontSize="11" FontWeight="SemiBold" Foreground="#8B7FB8"/>
            <TextBlock Text="Copyright &#169; 2026 Chulan Adasuriya"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="11" Foreground="#8B7FB8"/>
        </Grid>
    </Grid>
</Window>
